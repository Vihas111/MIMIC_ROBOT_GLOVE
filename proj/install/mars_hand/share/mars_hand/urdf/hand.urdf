    <origin xyz="0 0 0.031"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="0.8" effort="2" velocity="2"/>
    <dynamics damping="0.05" friction="0.02"/>
  </joint>

  <!-- ============================================================
       RING FINGER   seg1=44mm  seg2=28mm  seg3=20mm
  ============================================================ -->
