      <origin xyz="0 0 0.014"/>
      <inertia ixx="5.0e-7" ixy="0" ixz="0" iyy="5.0e-7" iyz="0" izz="2.1e-7"/>
    </inertial>
    <visual>
      <geometry><cylinder length="0.028" radius="0.0083"/></geometry>
      <origin xyz="0 0 0.014"/>
      <material name="seg_grey"/>
    </visual>
    <visual>
      <geometry><sphere radius="0.0090"/></geometry>
