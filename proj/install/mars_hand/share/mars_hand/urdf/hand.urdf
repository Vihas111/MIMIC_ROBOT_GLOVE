    <axis xyz="1 0 0"/>
    <limit lower="0" upper="0.9" effort="2" velocity="2"/>
    <dynamics damping="0.05" friction="0.02"/>
  </joint>

  <link name="pinky_seg2">
    <inertial>
      <mass value="0.004"/>
      <origin xyz="0 0 0.011"/>
      <inertia ixx="2.0e-7" ixy="0" ixz="0" iyy="2.0e-7" iyz="0" izz="1.1e-7"/>
