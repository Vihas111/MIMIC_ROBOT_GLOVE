  <!-- ============================================================
       PINKY FINGER   seg1=34mm  seg2=22mm  seg3=16mm
  ============================================================ -->
  <link name="pinky_seg1">
    <inertial>
      <mass value="0.006"/>
      <origin xyz="0 0 0.017"/>
      <inertia ixx="6.0e-7" ixy="0" ixz="0" iyy="6.0e-7" iyz="0" izz="1.9e-7"/>
    </inertial>
    <visual>
      <geometry><cylinder length="0.034" radius="0.0080"/></geometry>
