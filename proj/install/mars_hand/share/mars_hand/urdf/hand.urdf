    <axis xyz="1 0 0"/>
    <limit lower="0" upper="0.9" effort="2" velocity="2"/>
    <dynamics damping="0.05" friction="0.02"/>
  </joint>

  <link name="middle_seg2">
    <inertial>
      <mass value="0.006"/>
      <origin xyz="0 0 0.0155"/>
      <inertia ixx="6.0e-7" ixy="0" ixz="0" iyy="6.0e-7" iyz="0" izz="2.3e-7"/>
    </inertial>
    <visual>
      <geometry><cylinder length="0.031" radius="0.0087"/></geometry>
      <origin xyz="0 0 0.0155"/>
      <material name="seg_grey"/>
    </visual>
    <visual>
      <geometry><sphere radius="0.0094"/></geometry>
      <origin xyz="0 0 0.031"/>
      <material name="joint_dark"/>
    </visual>
    <collision>
      <geometry><cylinder length="0.031" radius="0.0087"/></geometry>
      <origin xyz="0 0 0.0155"/>
