    <child  link="ring_seg2"/>
    <origin xyz="0 0 0.044"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="1.2" effort="2" velocity="2"/>
    <dynamics damping="0.05" friction="0.02"/>
  </joint>

  <link name="ring_seg3">
