  </link>
  <joint name="middle_pip" type="revolute">
    <parent link="middle_seg1"/>
    <child  link="middle_seg2"/>
    <origin xyz="0 0 0.048"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="1.2" effort="2" velocity="2"/>
    <dynamics damping="0.05" friction="0.02"/>
  </joint>

  <link name="middle_seg3">
    <inertial>
      <mass value="0.005"/>
      <origin xyz="0 0 0.011"/>
      <inertia ixx="2.2e-7" ixy="0" ixz="0" iyy="2.2e-7" iyz="0" izz="1.6e-7"/>
    </inertial>
    <visual>
      <geometry><cylinder length="0.022" radius="0.0080"/></geometry>
      <origin xyz="0 0 0.011"/>
      <material name="seg_grey"/>
    </visual>
    <visual>
      <geometry><sphere radius="0.0088"/></geometry>
      <origin xyz="0 0 0.023"/>
      <material name="tip_white"/>
    </visual>
    <collision>
      <geometry><cylinder length="0.022" radius="0.0080"/></geometry>
      <origin xyz="0 0 0.011"/>
    </collision>
