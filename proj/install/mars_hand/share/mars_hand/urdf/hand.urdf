    <child  link="thumb_seg1"/>
    <origin xyz="0.010 0 0" rpy="0 1.5708 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="-1.2" upper="0.3" effort="2" velocity="2"/>
    <dynamics damping="0.05" friction="0.02"/>
  </joint>

  <link name="thumb_seg2">
    <inertial>
      <mass value="0.006"/>
      <origin xyz="0 0 0.015"/>
      <inertia ixx="5.0e-7" ixy="0" ixz="0" iyy="5.0e-7" iyz="0" izz="2.4e-7"/>
