  </link>
  <joint name="thumb_cmc" type="fixed">
    <parent link="palm"/>
    <child  link="thumb_bracket"/>
    <origin xyz="0.057 0 -0.008"/>
  </joint>

  <link name="thumb_seg1">
    <inertial>
      <mass value="0.008"/>
      <origin xyz="0 0 0.019"/>
      <inertia ixx="1.0e-6" ixy="0" ixz="0" iyy="1.0e-6" iyz="0" izz="3.7e-7"/>
